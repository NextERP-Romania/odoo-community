<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="account_analytic_distribution_model_tree" model="ir.ui.view">
        <field name="name">account.analytic.distribution.model.journal.tree</field>
        <field name="model">account.analytic.distribution.model</field>
        <field name="inherit_id" ref="analytic.account_analytic_distribution_model_tree_view"/>
        <field name="arch" type="xml">
            <field name="partner_category_id" position="after">
                <field name="journal_id" optional="show"/>
            </field>
        </field>
    </record>

    <record id="account_analytic_distribution_model_form" model="ir.ui.view">
        <field name="name">account.analytic.distribution.model.journal.form</field>
        <field name="model">account.analytic.distribution.model</field>
        <field name="inherit_id" ref="analytic.account_analytic_distribution_model_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_category_id']" position="after">
                <field name="journal_id"/>
            </xpath>
        </field>
    </record>

</odoo>
