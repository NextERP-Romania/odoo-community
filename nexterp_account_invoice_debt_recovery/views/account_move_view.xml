<?xml version="1.0" ?>
<odoo>
    <record id="view_move_debt_recovery_form" model="ir.ui.view">
        <field name="name">account.move.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <button id="account_invoice_payment_btn" position="attributes">
                <attribute name="invisible">
                    debt_company and (state != 'posted' or payment_state not in ['not_paid', 'partial', 'debt_recovery'] or move_type == 'entry')
                </attribute>
            </button>
            <button id="account_invoice_payment_btn" position="after">
                <button
                    name="action_mark_as_debt_recovery"
                    id="account_invoice_debt_recovery"
                    type="object"
                    class="oe_highlight"
                    invisible="debt_company and (debt_recovery != False or state != 'posted' or payment_state not in ['not_paid', 'partial'] or move_type != 'out_invoice')"
                    string="Mark as Debt Recovery"
                    groups="account.group_account_invoice"
                />
            </button>
            <field name="id" position="before">
                <widget
                    name="web_ribbon"
                    title="Debt Recovery"
                    invisible="payment_state != 'debt_recovery' or move_type != 'out_invoice'"
                />
            </field>
            <page id="other_tab_entry" position="after">
                <page
                    id="debt_recovery"
                    string="Debt Recovery"
                    name="debt_recovery_page"
                    invisible="move_type not in ['out_invoice'] or debt_recovery == False"
                >
                    <group id="debt_recovery_group">
                        <group name="debt_recovery">
                            <field name="debt_recovery" invisibile="1" />
                            <field name="debt_recovery_done" readonly="1" />
                            <field name="debt_state" invisibile="1" />
                            <field name="debt_case_date" invisibile="1" />
                        </group>
                        <group name="debt_recovery">
                            <field name="debt_law" invisibile="1" />
                            <field name="debt_amount" invisibile="1" />
                            <field name="debt_commission" invisibile="1" />
                            <field name="debt_penalties" invisibile="1" />
                            <field name="debt_company" invisibile="1" />
                        </group>
                    </group>
                    <!-- Debt Recovery note -->
                    <separator string="Debt Recovery Notes" />
                    <field
                        name="debt_recovery_text"
                        placeholder="Add an debt recovery note..."
                        nolabel="1"
                        height="150"
                    />
                </page>
            </page>
        </field>
    </record>

    <record id="view_out_invoice_tree_inherit_debt" model="ir.ui.view">
        <field name="name">account.move.tree.inherit.debt</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <field name="state" position="after">
                <field name="debt_state" optional="hide"/>
                <field name="debt_case_date" optional="hide"/>
            </field>
        </field>
    </record>
    <record id="view_out_invoice_search_inherit_debt" model="ir.ui.view">
        <field name="name">account.move.search.inherit.debt</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <filter name="status" position="after">
                <filter string="Payment Status" name="groupy_by_payment_state" domain="[]" context="{'group_by': 'payment_state'}"/>
            </filter>
            <filter name="late" position="after">
                <filter name="debt_recovery" string="Debt Recovery" domain="[('debt_recovery', '=', True)]"/>
            </filter>
        </field>
    </record>
        <record id="action_mark_as_debt_recovery" model="ir.actions.server">
        <field name="name">Mark as debt recovery</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="state">code</field>
        <field name="code">
            action_mark_as_debt_recovery()
        </field>
    </record>
</odoo>
