<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record model="ir.cron" id="ir_cron_res_company_einvoice_download_every_day">
        <field name="name">Romania e-Invoicing: Download Supplier Invoices</field>
        <field name="model_id" ref="base.model_res_company" />
        <field name="state">code</field>
        <field name="code">model._l10n_ro_create_anaf_efactura()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <!-- it s every day -->
    </record>

    <record model="ir.cron" id="ir_cron_res_company_send_toe_invoice">
        <field name="name">Send to ANAF E Invoice</field>
        <field name="model_id" ref="account.model_account_move" />
        <field name="state">code</field>
        <field name="code">model.send_email_invoice_anaf()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <!-- it s every day -->
    </record>

    <record model="ir.cron" id="ir_cron_res_company_fetch_einvoice">
        <field name="name">Fetch E-Factura Status</field>
        <field name="model_id" ref="account.model_account_move" />
        <field name="state">code</field>
        <field name="code">model.fetch_invoice_anaf()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <!-- it s every day -->
    </record>

</odoo>
