<?xml version="1.0" ?>
<odoo>

        <!-- Fiscal Year -->
        <record model="ir.ui.view" id="view_account_move_vehicle_form">
            <field name="name">account.move.line.form</field>
            <field name="model">account.move.line</field>
            <field name="inherit_id" ref="account.view_move_line_form" />
            <field name="arch" type="xml">
                <field name="account_id" position="after">
                    <field name="vehicle_id" />
                    <!-- <field name="refuel" /> -->
                </field>
            </field>
        </record>

        <record model="ir.ui.view" id="view_move_vehicle">
            <field name="name">account.move.vehicle.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form" />
            <field name="arch" type="xml">
                <!-- <div name="button_box" position="inside">
                    <field name="has_vehicle_contracts" invisible="1" />
                    <field name="has_vehicle_services" invisible="1" />
                    <button
                    name="action_open_vehicle_contract_costs"
                    class="oe_stat_button"
                    icon="fa-bars"
                    type="object"

                    string="Vehicle Contract Costs"
                >
                    </button>
                    <button
                    name="action_open_vehicle_service_costs"
                    class="oe_stat_button"
                    icon="fa-bars"
                    type="object"

                    string="Vehicle Service Costs"
                >
                    </button>
                </div> -->
                <xpath
                expr="//field[@name='line_ids']//field[@name='quantity']"
                position="before"
            >
                    <field
                    name="fleet_service_type_id"
                    invisible="parent.move_type  not in ('in_invoice', 'in_refund','in_receipt')"
                    column_invisible="parent.move_type not in ('in_invoice', 'in_refund','in_receipt')"
                />
                    <!-- <field
                    name="refuel"

                    invisible = "(parent.move_type  not in ('in_invoice', 'in_refund','in_receipt')) or (vehicle_id == False)"
                    column_invisible= "parent.move_type not in ('in_invoice', 'in_refund','in_receipt')"
                /> -->
                </xpath>
                <xpath
                expr="//field[@name='invoice_line_ids']//field[@name='quantity']"
                position="before"
            >
                <field
                    name="fleet_service_type_id"
                    invisible="parent.move_type  not in ('in_invoice', 'in_refund','in_receipt')"
                    column_invisible="parent.move_type not in ('in_invoice', 'in_refund','in_receipt')"
                />

                </xpath>
            </field>
        </record>
</odoo>
