<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="fleet_log_report_view_search" model="ir.ui.view">
        <field name="name">fleet.vehicle.log.view.search</field>
        <field name="model">fleet.vehicle.log.report</field>
        <field name="arch" type="xml">
            <search string="Fleet Costs Analysis">
                <!-- <field name="name" filter_domain="[('name', 'ilike', self)]"/>
                <field name="driver_id" filter_domain="[('driver_id', 'ilike', self)]"/> -->
                <field name="date" />
                <filter
                    string="Service"
                    name="service"
                    domain="[('cost_type', '=', 'service')]"
                />
                <filter
                    string="Contract"
                    name="contract"
                    domain="[('cost_type', '=', 'contract')]"
                />
                <separator />
                <filter
                    name="filter_date_start"
                    date="date"
                    default_period="this_year"
                />
                <!-- <group expand="1" string="Group By">
                    <filter string="Vehicle" name="vehicle" context="{'group_by':'vehicle_id'}"/>
                    <filter string="Driver" name="driver" context="{'group_by':'driver_id'}"/>
                </group> -->
            </search>
        </field>
    </record>

    <record id="fleet_costs_log_report_view_pivot" model="ir.ui.view">
        <field name="name">fleet.vehicle.log.view.pivot</field>
        <field name="model">fleet.vehicle.log.report</field>
        <field name="arch" type="xml">
            <pivot sample="1">
                <field name="date" type="col" interval="year" />
                <field name="cost_type" type="col" />
                <field name="vehicle_id" type="row" />
                 <field name="amount" type="measure" />
                <field name="quantity" type="measure" />

            </pivot>
        </field>
    </record>



    <record id="fleet_vechicle_log_report_view_tree" model="ir.ui.view">
        <field name="name">fleet.vehicle.log.report.view.tree</field>
        <field name="model">fleet.vehicle.log.report</field>
        <field name="arch" type="xml">
            <tree create="0">
                <field name="vehicle_id" />
                <field name="date" optional="show" />
                <field name="amount" optional="show" sum="Sum of Cost" />
                <field name="cost_type" optional="show" />
                <field name="quantity" optional="show" />
                <field name="company_id" groups="base.group_multi_company" />
            </tree>
        </field>
    </record>

    <record id="fleet_vechicle_log_report_view_form" model="ir.ui.view">
        <field name="name">fleet.vehicle.log.report.form</field>
        <field name="model">fleet.vehicle.log.report</field>
        <field name="arch" type="xml">
            <form string="Fleet Costs Analysis" create="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="vehicle_id" />

                            <field
                                name="company_id"
                                groups="base.group_multi_company"
                            />
                            <field name="stock_move_id" />
                            <field name="move_line_id" />
                            <field name="purchaser_id" />
                        </group>
                        <group>
                            <field name="date" />
                            <field name="amount" />
                            <field name="cost_type" />
                            <field name="quantity" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="fleet_log_reporting_action" model="ir.actions.act_window">
        <field name="name">Costs Analysis Log</field>
        <field name="res_model">fleet.vehicle.log.report</field>
        <field name="view_mode">pivot,tree,form</field>
        <field name="view_id" />
        <field name="context" eval="{'search_default_filter_date': 1}" />
        <field
            name="search_view_id"
            ref="nexterp_vehicle_costs.fleet_log_report_view_search"
        />
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">
              No data for analysis
            </p>
            <p>
              Manage efficiently your different effective vehicles Costs with Odoo.
            </p>
        </field>
    </record>

    <menuitem
        id="fleet_log_reporting_menu"
        name="Costs Log"
        parent="fleet.menu_fleet_reporting"
        action="fleet_log_reporting_action"
        sequence="1"
    />
</odoo>
