<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.stock</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <div name="operations_setting_container" position="inside">
                <div
                    class="col-12 col-lg-6 o_setting_box"
                    id="delivery_slip_report_setting_options"
                >
                    <div class="o_setting_left_pane" />

                    <div class="o_setting_right_pane">
                        <span class="o_form_label">Delivery slip report options</span>
                        <div class="text-muted">
                            Select the options you want to display on the delivery slip report
                        </div>

                        <div class="mt16">
                            <div class="content-group" id="delivery_slip_report">
                                <div>
                                    <field name="delivery_slip_report_only_name" />
                                    <label for="delivery_slip_report_only_name" />
                                </div>
                                <div>
                                    <field name="delivery_slip_report_uom_precision" />
                                    <label for="delivery_slip_report_uom_precision" />
                                </div>
                                <div>
                                    <field name="picking_report_lang_company" />
                                    <label for="picking_report_lang_company" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </field>
    </record>
</odoo>
