<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template
        id="report_delivery_document"
        inherit_id="stock.report_delivery_document"
        priority="100"
    >
        <xpath expr="//span[@t-field='move.product_id']" position="replace">
            <!-- Replace line product to print only name, not display name -->
            <t t-if="o.company_id.delivery_slip_report_only_name">
                <span t-esc="move.product_id.name" />
            </t>
            <t t-if="not o.company_id.delivery_slip_report_only_name">
                <span t-field="move.product_id" />
            </t>
        </xpath>
        <xpath expr="//span[@t-out='move.description_picking']" position="attributes">
            <!-- Hide product description if only_name is selected -->
            <attribute
                name="t-if"
            >not o.company_id.delivery_slip_report_only_name</attribute>
        </xpath>
        <!-- <span t-field="move.product_id"/> -->
        <xpath
            expr="//span[@t-out='format_number(move.product_uom_qty)']"
            position="attributes"
        >
            <!-- Replace line quantity with precision, round with line.product_uom precision -->
            <attribute name="t-options">
                {'widget': 'float', 'precision': move.product_uom.report_precision} if o.company_id.delivery_slip_report_uom_precision else {}
            </attribute>
        </xpath>
        <xpath
            expr="//span[@t-out='format_number(move.quantity)']"
            position="attributes"
        >
            <!-- Replace line quantity with precision, round with line.product_uom precision -->
            <attribute name="t-options">
                {'widget': 'float', 'precision': move.product_uom.report_precision} if o.company_id.delivery_slip_report_uom_precision else {}
            </attribute>
        </xpath>
    </template>
    <template
        id="stock_report_delivery_has_serial_move_line"
        inherit_id="stock.stock_report_delivery_has_serial_move_line"
        priority="100"
    >
        <xpath expr="//span[@t-field='move_line.product_id']" position="replace">
            <!-- Replace line product to print only name, not display name -->
            <t t-if="o.company_id.delivery_slip_report_only_name">
                <span t-esc="move_line.product_id.name" />
            </t>
            <t t-if="not o.company_id.delivery_slip_report_only_name">
                <span t-field="move_line.product_id" />
            </t>
        </xpath>
        <xpath expr="//span[@t-out='description']" position="attributes">
            <!-- Hide product description if only_name is selected -->
            <attribute
                name="t-if"
            >not o.company_id.delivery_slip_report_only_name</attribute>
        </xpath>

        <xpath
            expr="//span[@t-out='format_number(move_line.quantity)']"
            position="attributes"
        >
            <attribute name="t-options">
                {'widget': 'float', 'precision': move_line.product_uom.report_precision} if o.company_id.delivery_slip_report_uom_precision else {}
            </attribute>
        </xpath>
    </template>
    <template
        id="stock_report_delivery_aggregated_move_lines"
        inherit_id="stock.stock_report_delivery_aggregated_move_lines"
    >
        <xpath
            expr="//span[@t-esc=&quot;aggregated_lines[line]['description']&quot;]"
            position="attributes"
        >
            <attribute
                name="t-if"
            >not o.company_id.delivery_slip_report_only_name</attribute>
        </xpath>

        <xpath
            expr="//span[@t-out=&quot;format_number(aggregated_lines[line]['qty_ordered'])&quot;]"
            position="attributes"
        >
            <attribute name="t-options">
                {'widget': 'float', 'precision': aggregated_lines[line]['report_precision']} if o.company_id.delivery_slip_report_uom_precision else {}
            </attribute>
        </xpath>
        <xpath
            expr="//span[@t-out=&quot;format_number(aggregated_lines[line]['quantity'])&quot;]"
            position="attributes"
        >
            <attribute name="t-options">
                {'widget': 'float', 'precision': aggregated_lines[line]['report_precision']} if o.company_id.delivery_slip_report_uom_precision else {}
            </attribute>
        </xpath>
    </template>
</odoo>
