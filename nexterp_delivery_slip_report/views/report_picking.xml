<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <template id="report_delivery_document" inherit_id="stock.report_delivery_document">
        <xpath expr="//span[@t-field='move.product_id']" position="replace">
            <!-- Replace line product to print only name, not display name -->
            <t t-if="o.company_id.delivery_slip_report_only_name">
                <span t-esc="move.product_id.name"/>
            </t>
            <t t-if="not o.company_id.delivery_slip_report_only_name">
                <span t-field="move.product_id"/>
            </t>
        </xpath>
        <xpath expr="//span[@t-field='move.description_picking']" position="attributes">
            <!-- Hide product description if only_name is selected -->
            <attribute name="t-if" set="not move.company_id.delivery_slip_report_only_name"/>
        </xpath>
        <!-- <span t-field="move.product_id"/> -->
        <xpath expr="//span[@t-field='move.product_uom_qty']" position="attributes">
            <!-- Replace line quantity with precision, round with line.product_uom precision -->
            <attribute name="t-options" t-if="o.company_id.delivery_slip_report_uom_precision">
                {'precision': move.product_uom.report_precision}
            </attribute>
        </xpath>
        <xpath expr="//span[@t-field='move.quantity_done']" position="attributes">
            <!-- Replace line quantity with precision, round with line.product_uom precision -->
            <attribute name="t-options" t-if="o.company_id.delivery_slip_report_uom_precision">
                {'precision': move.product_uom.report_precision}
            </attribute>
        </xpath>
    </template>
    <template id="stock_report_delivery_has_serial_move_line" inherit_id="stock.stock_report_delivery_has_serial_move_line">
        <xpath expr="//span[@t-field='move_line.product_id']" position="replace">
            <!-- Replace line product to print only name, not display name -->
            <t t-if="o.company_id.delivery_slip_report_only_name">
                <span t-esc="move_line.product_id.name"/>
            </t>
            <t t-if="not o.company_id.delivery_slip_report_only_name">
                <span t-field="move_line.product_id"/>
            </t>
        </xpath>
        <xpath expr="//span[@t-esc='description']" position="attributes">
            <!-- Hide product description if only_name is selected -->
            <attribute name="t-if" set="not o.company_id.delivery_slip_report_only_name"/>
        </xpath>

        <xpath expr="//span[@t-field='move_line.qty_done']" position="attributes">
            <!-- Replace line quantity with precision, round with line.product_uom precision -->
            <attribute name="t-options" t-if="o.company_id.delivery_slip_report_uom_precision">
                {'precision': ml.product_uom.report_precision}
            </attribute>
        </xpath>
    </template>
    <template id="stock_report_delivery_aggregated_move_lines" inherit_id="stock.stock_report_delivery_aggregated_move_lines">
        <xpath expr="//span[@t-esc=&quot;aggregated_lines[line]['description']&quot;]" position="attributes">
            <!-- Hide product description if only_name is selected -->
            <attribute name="t-if" set="not o.company_id.delivery_slip_report_only_name"/>
        </xpath>
        
        <xpath expr="//span[@t-esc=&quot;aggregated_lines[line]['qty_ordered']&quot;]" position="attributes">
            <!-- Replace line quantity with precision, round with line.product_uom_id precision -->
            <attribute name="t-options" t-if="o.company_id.delivery_slip_report_uom_precision">
                {'widget': 'float', 'precision': aggregated_lines[line]['report_precision']}
            </attribute>
        </xpath><xpath expr="//span[@t-esc=&quot;aggregated_lines[line]['qty_done']&quot;]" position="attributes">
            <!-- Replace line quantity with precision, round with line.product_uom_id precision -->
            <attribute name="t-options" t-if="o.company_id.delivery_slip_report_uom_precision">
                {'widget': 'float', 'precision': aggregated_lines[line]['report_precision']}
            </attribute>
        </xpath>
    </template>
</odoo>
