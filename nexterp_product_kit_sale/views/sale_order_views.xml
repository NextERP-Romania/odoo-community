<?xml version="1.0" ?>
<odoo>
    <record id="sale_order_form_quote" model="ir.ui.view">
        <field name="name">sale.order.form.payment</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//page/field[@name='order_line']/.." position="after">
                <page string="Kit Order Lines" name="kit_line_ids">
                    <field name="kit_line_ids" readonly="state == 'cancel' or locked">
                        <list
                            string="Kit Lines"
                            editable="bottom"
                            default_group_by="sale_line_id"
                            decoration-muted="display_type"
                        >
                            <field name="display_type" column_invisible="1" />
                            <field name="currency_id" column_invisible="1" />
                            <field name="sequence" widget="handle" />
                            <field
                                name="sale_line_id"
                                required="not display_type"
                                options="{'no_create': True, 'no_open': True}"
                            />
                            <field
                                name="product_id"
                                required="not display_type"
                                context="{
                                    'default_uom_id': product_uom_id,
                                    'partner_id': parent.partner_id,
                                }"
                            />
                            <field name="name" optional="hide" />
                            <field name="product_uom_qty" string="Quantity" />
                            <field
                                name="product_uom_id"
                                groups="uom.group_uom"
                                widget="many2one_uom"
                                options="{'no_open': True, 'no_create': True}"
                                optional="show"
                            />
                            <field name="price_unit" />
                            <field
                                name="tax_ids"
                                widget="many2many_tax_tags"
                                options="{'no_create': True}"
                                optional="hide"
                            />
                            <field
                                name="price_subtotal"
                                sum="Total"
                                widget="monetary"
                            />
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
