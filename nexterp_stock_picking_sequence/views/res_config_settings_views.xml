<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.stock</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <setting id="process_transfers" position="after">
                <setting
                    id="stock_assign_number_in_process"
                    company_dependent="1"
                    help="Assign picking number in action done"
                >
                    <field
                        name="stock_assign_number_in_process"
                        widget="upgrade_boolean"
                    />
                    <div
                        class="row mt16"
                        invisible="not stock_assign_number_in_process"
                    >
                        <label
                            for="draft_picking_sequence_id"
                            class="col-lg-4 o_light_label"
                        />
                        <field name="draft_picking_sequence_id" class="oe_inline" />
                    </div>
                </setting>

            </setting>
        </field>
    </record>
</odoo>
