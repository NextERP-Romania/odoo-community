<?xml version="1.0" ?>
<odoo>
    <!-- Inventory stock - views and menu -->
    <!-- Form view -->
    <record model="ir.ui.view" id="inventory_stock_form_view">
        <field name="name">l10n.ro.stock.inventory.form</field>
        <field name="model">l10n.ro.stock.inventory</field>
        <field name="arch" type="xml">
            <form string="Inventory stock adjustments">
                <field name="state" invisible="1" />
                <field name="inventory_lines_generated" invisible="1" />
                <header>
                    <button
                        name="action_validate_inventory"
                        attrs="{'invisible': ['|', ('state', '=', 'done'), ('inventory_lines_generated', '=', False)]}"
                        string="Validate Inventory"
                        type="object"
                        class="oe_highlight"
                        groups="base.group_user"
                    />
                    <button
                        name="action_generate_inventory_lines"
                        attrs="{'invisible': [('state', '=', 'done')]}"
                        string="Generate Inventory Lines"
                        type="object"
                        class="o_btn_validate"
                        groups="base.group_user"
                    />
                    <button
                        name="action_clear_inventory_lines"
                        attrs="{'invisible': ['|', ('state', '=', 'done'), ('inventory_lines_generated', '=', False)]}"
                        string="Clear Inventory Lines"
                        type="object"
                        class="o_btn_validate"
                        groups="base.group_user"
                    />
                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="draft,done"
                    />
                </header>
                <sheet>

                    <group>
                        <group>
                            <field name="name" />
                            <field
                                name="accounting_date"
                                widget="date"
                                attrs="{'readonly': [('state', '=', 'done')]}"
                            />
                            <field
                                name="location_ids"
                                widget="many2many_tags"
                                options="{'no_create': True}"
                                attrs="{'readonly': [('state', '=', 'done')]}"
                            />
                            <field
                                name="product_ids"
                                widget="many2many_tags"
                                options="{'no_create': True}"
                                attrs="{'readonly': [('state', '=', 'done')]}"
                            />
                        </group>
                    </group>
                    <notebook>
                        <page string="Inventory Lines">
                            <field
                                name="inventory_line_ids"
                                mode="tree"
                                widget="stock_move_one2many"
                                attrs="{'readonly': [('state', '=', 'done')]}"
                            >
                                <tree editable="bottom">
                                    <field
                                        name="location_id"
                                        domain="[('id', 'in', parent.location_ids)]"
                                        options="{'no_create': True}"
                                    />
                                    <field
                                        name="product_id"
                                        domain="[('id', 'in', parent.product_ids)]"
                                        options="{'no_create': True}"
                                    />
                                    <field
                                        name="product_lot_id"
                                        domain="[('product_id', 'in', parent.product_ids)]"
                                        context="{'default_product_id': product_id}"
                                    />
                                    <field
                                        name="standard_price"
                                        attrs="{'invisible': [('inventory_diff_quantity', '&lt;=', 0)]}"
                                        widget='monetary'
                                    />
                                    <field name="quantity" />
                                    <field name="product_uom_id" />
                                    <field
                                        name="inventory_quantity"
                                        options="{'autosave': True}"
                                    />
                                    <field name="inventory_diff_quantity" />
                                    <field name="value" sum="Value" />
                                    <field name="inventory_value" sum="New value" />
                                    <field name="inventory_diff_value" sum="Diff" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree view -->
    <record model="ir.ui.view" id="inventory_stock_tree_view">
        <field name="name">l10n.ro.stock.inventory.tree</field>
        <field name="model">l10n.ro.stock.inventory</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="accounting_date" />
                <field name="state" />
            </tree>
        </field>
    </record>

    <!-- Search view -->
    <record id="inventory_stock_search_view" model="ir.ui.view">
        <field name="name">l10n.ro.stock.inventory.search</field>
        <field name="model">l10n.ro.stock.inventory</field>
        <field name="arch" type="xml">
            <search string="Inventory">
                <field name="product_ids" domain="[('id', 'in', product_ids)]" />
                <field
                    name="location_ids"
                    domain="[('location_id', 'in', location_ids)]"
                />

                <filter
                    name="inventory_draft"
                    string="Draft"
                    domain="[('state', '=', 'draft')]"
                />
                <filter
                    name="inventory_done"
                    string="Done"
                    domain="[('state', '=', 'done')]"
                />
                <filter
                    name="filter_accounting_date"
                    date="accounting_date"
                    string="Accounting Date"
                    default_period="this_year"
                />

                <group expand="1" string="Group By">
                    <filter
                        string="State"
                        name="state"
                        context="{'group_by':'state'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <!-- Open window action -->
    <record id="action_open_stock_inventory" model="ir.actions.act_window">
        <field name="name">Inventory Stock Adjustments</field>
        <field name="res_model">l10n.ro.stock.inventory</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="inventory_stock_tree_view" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first inventory stock adjustment
            </p>
        </field>
    </record>

    <!-- Menu item -->
    <menuitem
        id="menu_action_stock_inventory_tree"
        name="Inventory Stock Adjustments"
        parent="stock.menu_stock_warehouse_mgmt"
        action="action_open_stock_inventory"
        groups="stock.group_stock_manager"
    />
</odoo>
